{
  "name": "chrome-translator",
  "displayName": "双语翻译助手",
  "version": "1.1.0",
  "description": "自用双语翻译 Chrome 插件 - 英译中，支持自定义 LLM",
  "author": "amkkrr",
  "scripts": {
    "dev": "node scripts/gen-version.mjs && plasmo dev",
    "build": "node scripts/gen-version.mjs && plasmo build",
    "package": "plasmo package",
    "prepare": "husky"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "0.90.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "0.0.287",
    "@types/node": "20.14.9",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "husky": "^9.1.7",
    "prettier": "3.3.3",
    "typescript": "5.5.3"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "storage",
      "activeTab"
    ]
  }
}
